# Example environment file — copy to .env and fill in your values.
# DO NOT commit .env to git (it may contain secrets).

# ─── Backend API URL ──────────────────────────────────────────
# Development:   VITE_API_BASE_URL=http://localhost:5000/api
# Production:    VITE_API_BASE_URL=http://<your-server-ip>:5001/api
VITE_API_BASE_URL=http://156.67.105.52:5001/api

# ─── WebSocket / Socket.IO server URL ─────────────────────────
# Must be the root of the backend server (no /api suffix)
# Development:   VITE_SOCKET_URL=http://localhost:5000
# Production:    VITE_SOCKET_URL=http://<your-server-ip>:5001
VITE_SOCKET_URL=http://156.67.105.52:5001

# ─── Frontend URL (used for QR code links) ────────────────────
# Set this to your deployed Netlify/Vercel/custom domain URL
VITE_FRONTEND_URL=https://aiwaitercall.netlify.app
